# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Bill Translator — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file:  cp .env.example .env
# Then fill in your values below.
# API keys can also be entered in the browser (BYOK) instead of here.

# Required: Anthropic API key (or enter in the browser per-session)
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-PASTE-YOUR-KEY-HERE

# Optional: Brave Search API key (enables fact-checking feature)
# Get yours at https://api-dashboard.search.brave.com/
# BRAVE_SEARCH_API_KEY=

# Optional: Flask secret key (auto-generated if not set, but set for
# persistent sessions across restarts)
# FLASK_SECRET_KEY=

# Optional: Set to "1" or "true" for development auto-reload
# FLASK_DEBUG=false

# Optional: Override HTTP port (default: 5000)
# PORT=5000

# Optional: Override Claude model
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Max upload size in MB (default: 10)
# MAX_UPLOAD_SIZE_MB=10
